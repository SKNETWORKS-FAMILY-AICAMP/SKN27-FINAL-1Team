# ============================================================
# 밥벌이(bobbeori) 공식 통합 환경변수 정의 샘플 (.env.sample)
# ============================================================

# ────────────────────────────────────────
# 1. 웹 서버 및 디버그 설정
# ────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEV_MODE=True

# ────────────────────────────────────────
# 2. 관계형 데이터베이스 (PostgreSQL/RDB) - 김재묵 담당
# ────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=bobbeori_user
DB_PASSWORD=YOUR_SECURE_RDB_PASSWORD_HERE
DB_NAME=bobbeori_db

# ────────────────────────────────────────
# 3. Neo4j 그래프 데이터베이스 설정 - 김경수·김주영 담당
# ────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=YOUR_SECURE_NEO4J_PASSWORD_HERE
NEO4J_DATABASE=neo4j

# ────────────────────────────────────────
# 4. 인증 및 보안 설정 (Auth / Security) - 김재묵 담당
# ────────────────────────────────────────
JWT_SECRET_KEY=YOUR_JWT_SECRET_KEY_HERE
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# 소셜 로그인 인증 자격 증명 (Kakao / Naver / Google)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/kakao/callback
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/naver/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback/google
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:5173/auth/callback/google-calendar

# ────────────────────────────────────────
# 5. OpenAI 및 LLM / 에이전트 설정 - 공용
# ────────────────────────────────────────
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
OPENAI_MODEL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
TAVILY_API_KEY=YOUR_TAVILY_API_KEY_HERE

# LangChain / LangGraph 실험 트래킹 (선택사항)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=YOUR_LANGCHAIN_API_KEY_HERE
LANGCHAIN_PROJECT=bobbeori-ai-experiment

# ────────────────────────────────────────
# 6. OCR 설정 (로컬 엔진 및 외부 API 지원) - 박준희 담당
# ────────────────────────────────────────
OCR_ENGINE=openai_vision
OCR_LANGUAGES=ko
OCR_MODEL=gpt-5.4-mini
# OCR_FALLBACK_MODEL=gpt-5.5
OCR_UPLOAD_DIR=storage/raw/receipts         # 원본 이미지 저장
OCR_OUTPUT_DIR=storage/processed/receipts   # OCR JSON 결과 저장
MAX_UPLOAD_SIZE_MB=10

# CLOVA OCR 연동 시 필요 필드
CLOVA_OCR_SECRET_KEY=YOUR_CLOVA_OCR_KEY_IF_NEEDED
CLOVA_OCR_APIGW_URL=YOUR_CLOVA_URL_IF_NEEDED

# ────────────────────────────────────────
# 7. ETL 및 데이터 디렉터리 경로 설정
# ────────────────────────────────────────
STORAGE_RAW_DIR=storage/raw
STORAGE_PROCESSED_DIR=storage/processed
STORAGE_MOCK_DIR=storage/mock
RECIPE_RAW_DIR=storage/raw/recipe
RECIPE_PROCESSED_DIR=storage/processed/recipe
FOOD_GUIDE_RAW_DIR=storage/raw/food_guide
FOOD_GUIDE_PROCESSED_DIR=storage/processed/food_guide
NEO4J_IMPORT_DIR=storage/neo4j/import
NEO4J_CYPHER_DIR=storage/neo4j/cypher

# ────────────────────────────────────────
# 8. 데이터 수집 및 크롤링 (Crawling / Scraping) - 김주영 담당
# ────────────────────────────────────────
SCRAPER_USER_AGENT=bobbeori-final-project/0.1
SCRAPER_REQUEST_TIMEOUT_SECONDS=10
SCRAPER_SLEEP_SECONDS=1
SELENIUM_HEADLESS=true

# ────────────────────────────────────────
# 9. 공공데이터 및 기타 외부 API (선택사항)
# ────────────────────────────────────────
DATA_GO_KR_SERVICE_KEY=
DART_API_KEY=

# ────────────────────────────────────────
# 10. 로그 관리 (Logging)
# ────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs

# ────────────────────────────────────────
# 11. Runpod 관리 (calendar_mcp)
# ────────────────────────────────────────
RUNPOD_CALENDAR_MCP_URL=
RUNPOD_INTERNAL_TOKEN=
RUNPOD_TIMEOUT_SECONDS=
